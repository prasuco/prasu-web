---
import { getCollection } from "astro:content";
import Main from "@/layouts/main.astro";

function formatDate(date: string | Date) {
  return new Date(date).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}

export async function getStaticPaths() {
	const blogs = await getCollection("blogs");
	return blogs.map((blog) => ({
		params: { slug: blog.slug },
		props: { project: blog },
	}));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<Main title={`${project.data.title} - Prasuco Blog`}>
	<article class="prose prose-neutral dark:prose-invert max-w-none">
		<header class="mb-10 not-prose">
			<a href="/blogs" class="text-[13px] text-text-secondary-light dark:text-text-secondary-dark hover:text-accent-green mb-6 inline-block font-mono">
				← back
			</a>
			
			<h1 class="text-[32px] font-semibold text-text-primary-light dark:text-text-primary-dark mb-4 leading-tight">
				{project.data.title}
			</h1>
			
			<p class="text-[18px] text-text-secondary-light dark:text-text-secondary-dark mb-6 leading-relaxed">
				{project.data.description}
			</p>

			<div class="flex flex-wrap items-center gap-4 text-[13px] font-mono text-text-secondary-light dark:text-text-secondary-dark">
				<span>{formatDate(project.data.publishDate)}</span>
				<span class="opacity-50">/</span>
				<span>{project.data.author}</span>
				{project.data.tags && project.data.tags.length > 0 && (
					<div class="flex items-center gap-2">
						<span class="opacity-50">/</span>
						<span>{project.data.tags.map(t => `#${t}`).join(" ")}</span>
					</div>
				)}
			</div>
		</header>

		<div class="mt-12">
			<Content />
		</div>
	</article>
</Main>